{
  "chain_test_1": {
    "name": "订单创建到履约全流程",
    "description": "测试从订单捕获到最终履约的完整流程",
    "steps": [
      {
        "skill": "order_capture",
        "action": "normalize",
        "input": {
          "order": {
            "order_id": "ORD_CHAIN_001",
            "source_order_id": "TB123456789",
            "channel": "taobao",
            "phone": "13800138000",
            "receiver_address": "上海市浦东新区张江路100号",
            "items": [
              {"sku_code": "SKU001", "num": 2, "price": 99.00}
            ],
            "goods_amount": 198.00,
            "shipping_fee": 10.00,
            "discount_amount": 20.00,
            "total_amount": 188.00,
            "created_time": "2024-01-20T10:00:00"
          }
        }
      },
      {
        "skill": "one_id_merge",
        "action": "identify",
        "input": {
          "identifier": {
            "type": "phone",
            "value": "13800138000"
          }
        }
      },
      {
        "skill": "inventory_realtime",
        "action": "check_overselling",
        "input": {
          "sku_id": "SKU001",
          "quantity": 2
        }
      },
      {
        "skill": "promotion_engine",
        "action": "calculate_discount",
        "input": {
          "order": {
            "order_id": "ORD_CHAIN_001",
            "goods_amount": 198.00,
            "items": [
              {"sku_id": "SKU001", "price": 99.00, "quantity": 2}
            ]
          },
          "promotions": [
            {
              "promo_id": "P001",
              "type": "COUPON",
              "discount_type": "FIXED",
              "discount_value": 20,
              "min_amount": 100,
              "start_time": "2024-01-01",
              "end_time": "2024-12-31",
              "remaining_quota": 1000
            }
          ]
        }
      },
      {
        "skill": "order_routing",
        "action": "route",
        "input": {
          "order": {
            "order_id": "ORD_CHAIN_001",
            "customer_lat": 31.2304,
            "customer_lon": 121.4737
          },
          "warehouses": [
            {"id": "WH001", "name": "上海仓", "lat": 31.2304, "lon": 121.4737},
            {"id": "WH002", "name": "武汉仓", "lat": 30.5928, "lon": 114.3055}
          ],
          "stores": [
            {"id": "STORE001", "name": "浦东店", "lat": 31.2304, "lon": 121.4737}
          ]
        }
      },
      {
        "skill": "profit_sharing",
        "action": "calculate_commission",
        "input": {
          "order": {
            "order_id": "ORD_CHAIN_001",
            "order_amount": 168.00,
            "source_channel": "taobao",
            "category": "ELECTRONICS"
          },
          "commission_rules": {
            "channels": {
              "taobao": {
                "categories": {
                  "ELECTRONICS": {
                    "commission_rate": 0.05,
                    "platform_fee_rate": 0.02
                  }
                }
              }
            }
          }
        }
      }
    ]
  },
  "chain_test_2": {
    "name": "退货处理全流程",
    "description": "测试从退货申请到库存回收的完整流程",
    "steps": [
      {
        "skill": "returns_crosschannel",
        "action": "check_eligibility",
        "input": {
          "order": {
            "order_id": "ORD_CHAIN_002",
            "created_at": "2024-01-20T10:00:00",
            "max_return_days": 7,
            "items": [
              {"sku_id": "SKU001", "final_price": 99.00}
            ],
            "return_status": null
          },
          "return_request": {}
        }
      },
      {
        "skill": "returns_crosschannel",
        "action": "process_refund",
        "input": {
          "return_request": {
            "refund_method": "ORIGINAL",
            "include_shipping": false,
            "coupon_returned": true
          },
          "order": {
            "order_id": "ORD_CHAIN_002",
            "items": [
              {"sku_id": "SKU001", "final_price": 99.00}
            ],
            "shipping_fee": 10.00
          }
        }
      },
      {
        "skill": "returns_logistics",
        "action": "track",
        "input": {
          "tracking_number": "RTN123456789"
        }
      },
      {
        "skill": "returns_logistics",
        "action": "quality_check",
        "input": {
          "check_request": {
            "return_id": "RET001",
            "sku_id": "SKU001",
            "quantity": 1
          }
        }
      },
      {
        "skill": "returns_logistics",
        "action": "classify_defect",
        "input": {
          "defect_info": {
            "return_id": "RET001",
            "defect_type": "QUALITY_ISSUE",
            "severity": "MEDIUM"
          }
        }
      },
      {
        "skill": "inventory_ringfence",
        "action": "check",
        "input": {
          "sku_id": "SKU001",
          "channel": "taobao",
          "quantity": 1
        }
      }
    ]
  },
  "chain_test_3": {
    "name": "对账全流程",
    "description": "测试从账单核对到凭证生成的完整流程",
    "steps": [
      {
        "skill": "reconciliation",
        "action": "reconcile",
        "input": {
          "platform_bills": [
            {"channel": "taobao", "order_id": "ORD001", "amount": 100.00},
            {"channel": "taobao", "order_id": "ORD002", "amount": 200.00},
            {"channel": "jd", "order_id": "JD001", "amount": 150.00}
          ],
          "system_bills": [
            {"channel": "taobao", "order_id": "ORD001", "amount": 100.00},
            {"channel": "taobao", "order_id": "ORD002", "amount": 180.00},
            {"channel": "jd", "order_id": "JD001", "amount": 150.00}
          ]
        }
      },
      {
        "skill": "reconciliation",
        "action": "generate_voucher",
        "input": {
          "bill": {
            "order_id": "ORD001",
            "channel": "taobao",
            "amount": 100.00,
            "type": "INCOME"
          },
          "voucher_type": "INCOME"
        }
      },
      {
        "skill": "reconciliation",
        "action": "export_report",
        "input": {
          "bills": [
            {"channel": "taobao", "amount": 280.00, "type": "INCOME"},
            {"channel": "jd", "amount": 150.00, "type": "INCOME"}
          ],
          "period": {
            "start_date": "2024-01-01",
            "end_date": "2024-01-31"
          }
        }
      }
    ]
  }
}
